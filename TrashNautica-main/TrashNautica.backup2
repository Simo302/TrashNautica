ctjsVersion: 5.2.1
backups: 3
language: typescript
notes: /* empty */
libs:
  place:
    gridX: 1024
    gridY: 1024
    debugMode: false
    debugText: 0
  pointer:
    startlocked: false
  keyboard: {}
  keyboard.polyfill: {}
  pointer.polyfill: {}
  gamepad: {}
  vkeys: {}
startroom: n8zd3bf8c5jPWg
contentTypes: []
actions:
  - name: P1MoveX
    methods:
      - code: keyboard.KeyD
      - code: keyboard.KeyA
        multiplier: -1
      - code: gamepad.Right
      - code: gamepad.Left
        multiplier: -1
      - code: gamepad.LStickX
      - code: vkeys.Vjoy1X
  - name: P1MoveY
    methods:
      - code: keyboard.KeyW
        multiplier: -1
      - code: keyboard.KeyS
scripts:
  - name: tutto
    code: |+
      /* Use scripts to define frequent functions and import small libraries */

      // Gestione pausa
      const pause = {
          isPaused: false,
          togglePaused: function () {
              this.isPaused = !this.isPaused;
          }
      }

