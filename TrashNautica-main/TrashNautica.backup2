        lastmod: 1774250395620
        entries:
          - type: template
            baseClass: AnimatedSprite
            name: Medusa
            depth: 0
            texture: 7Krn257QNQT37Q
            playAnimationOnStart: false
            loopAnimation: true
            animationFPS: 30
            visible: true
            events:
              - eventKey: OnStep
                lib: core
                code: |-
                  if (!pause.isPaused) {
                      if (place.occupied(this, this.x + 5, this.y, 'Terreno')) {
                          this.direction = 180;
                      } else if (place.occupied(this, this.x - 5, this.y, 'Terreno')) {
                          this.direction = 0;
                      }

                      this.move();
                  }
                arguments: {}
              - eventKey: OnCreate
                code: |-
                  this.speed = 150;
                  this.direction = 0;
                arguments: {}
                lib: core
            extends:
              cgroup: Nemici
            lastmod: 1774251429249
            uid: MPdrNr8hhh5b2R
